---
// Gilt & Grove — Frame
// The signature container: a woven Celtic braid border that ties a knot at
// each corner and tapers to a single line mid-edge. Generated to fit any
// size (client-side, regenerated on resize). Use to enshrine key content.
interface Props {
  tone?: 'duo' | 'gold' | 'green' | 'bronze';
  class?: string;
  pad?: string;
  surface?: string;
  [key: string]: unknown;
}
const { tone = 'duo', class: className = '', pad, surface, ...rest } = Astro.props;
const style = pad ? `--frame-pad:${pad}` : undefined;
---

<div
  class:list={['gg-frame2', className]}
  data-gg-frame
  data-tone={tone}
  data-surface={surface}
  style={style}
  {...rest}
>
  <svg class="gg-frame2__art" aria-hidden="true" preserveAspectRatio="none"></svg>
  <div class="gg-frame2__inner"><slot /></div>
</div>

<style>
  .gg-frame2 {
    position: relative;
    padding: var(--frame-pad, clamp(var(--space-6), 5vw, var(--space-8)));
    background: transparent;
  }
  .gg-frame2__art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }
  .gg-frame2__inner { position: relative; }
</style>

<script>
  import { frameBraid } from '../lib/knots.mjs';
  import { plaitFrame } from '../lib/ornaments.mjs';

  // Rope cords use CSS vars (resolve via style); the engraved plait writes hex
  // presentation attributes (where var() would not resolve), so it has its own
  // tone map. Both default to the antique gold tie.
  const toneCord: Record<string, string> = {
    duo: 'var(--metal)',
    gold: 'var(--metal)',
    green: 'var(--accent-green)',
    bronze: 'var(--gold-600)',
  };
  const plaitCord: Record<string, string> = {
    duo: '#B18A44',
    gold: '#B18A44',
    green: '#5F7456',
    bronze: '#8D6B31',
  };

  function paint(el: HTMLElement) {
    const svg = el.querySelector<SVGSVGElement>('.gg-frame2__art');
    if (!svg) return;
    const w = Math.round(el.offsetWidth);
    const h = Math.round(el.offsetHeight);
    if (w < 60 || h < 60) { svg.innerHTML = ''; return; }
    svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
    const tone = el.dataset.tone || 'duo';
    const surface = el.dataset.surface || 'var(--bg)';
    const strandProp = el.dataset.strandProp ? parseFloat(el.dataset.strandProp) : undefined;
    const maxTile = el.dataset.maxTile ? parseFloat(el.dataset.maxTile) : undefined;
    const taper = 'taper' in el.dataset;
    const taperStrength = el.dataset.taperStrength ? parseFloat(el.dataset.taperStrength) : undefined;
    const globalMode = document.documentElement.dataset.ornament || 'plaited';
    const mode = el.dataset.hand || globalMode;
    svg.innerHTML =
      mode === 'woven'
        ? frameBraid(w, h, { cord: toneCord[tone] || 'var(--metal)', bg: surface, strandProp, maxTile, taper, taperStrength })
        : plaitFrame(w, h, { cord: plaitCord[tone] || '#B18A44', bg: '#121110', strandProp, maxTile, taper, taperStrength });
  }

  const frames = document.querySelectorAll<HTMLElement>('[data-gg-frame]');
  if ('ResizeObserver' in window) {
    const ro = new ResizeObserver((entries) => {
      for (const e of entries) paint(e.target as HTMLElement);
    });
    frames.forEach((el) => { paint(el); ro.observe(el); });
    new MutationObserver((mutations) => {
      for (const mut of mutations) {
        for (const node of mut.addedNodes) {
          if (!(node instanceof HTMLElement)) continue;
          const added = [
            ...(node.matches('[data-gg-frame]') ? [node as HTMLElement] : []),
            ...Array.from(node.querySelectorAll<HTMLElement>('[data-gg-frame]')),
          ];
          added.forEach((el) => { paint(el); ro.observe(el); });
        }
      }
    }).observe(document.body, { childList: true, subtree: true });
  } else {
    frames.forEach(paint);
    window.addEventListener('resize', () => frames.forEach(paint));
  }

  // Repaint every frame when the ornament-set preview switch flips.
  new MutationObserver(() => frames.forEach(paint)).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-ornament'],
  });
</script>
