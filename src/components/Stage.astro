---
// Gilt & Grove — Stage
// The layered, parallaxing backdrop the acts play out over. Every layer is
// ambient and decorative (aria-hidden); without JS it's a still, on-brand
// candle-lit ground. With cinema on, each [data-parallax] layer drifts at its
// own depth and each [data-aura] bloom cross-fades as its act holds the view.
const glints = [
  { top: '18%', left: '12%', s: 7, d: 0.9 },
  { top: '32%', left: '82%', s: 5, d: 1.4 },
  { top: '54%', left: '24%', s: 6, d: 1.1 },
  { top: '66%', left: '70%', s: 8, d: 0.7 },
  { top: '80%', left: '40%', s: 5, d: 1.3 },
  { top: '44%', left: '54%', s: 4, d: 1.0 },
];
---

<div class="stage" aria-hidden="true">
  <!-- Deepest: the Celtic plait lattice, drifting slowest -->
  <div class="stage__lattice" data-parallax data-speed="0.12"></div>

  <!-- Per-act aura blooms — cross-fade as their act enters -->
  <div class="stage__aura stage__aura--hero" data-parallax data-speed="0.06" data-aura="invitation"></div>
  <div class="stage__aura stage__aura--story" data-parallax data-speed="0.18" data-aura="story"></div>

  <!-- Nearest: fine gold motes drifting fastest -->
  <div class="stage__glints" data-parallax data-speed="0.34">
    {glints.map((g) => (
      <span
        class="stage__glint"
        style={`top:${g.top};left:${g.left};--gs:${g.s}px;--gd:${g.d}`}
      ></span>
    ))}
  </div>
</div>

<style>
  .stage {
    position: fixed;
    inset: 0;
    z-index: var(--z-base);
    pointer-events: none;
    overflow: hidden;
  }
  .stage > * { position: absolute; inset: -12% 0; }

  .stage__lattice {
    background-image: url('../../design-system/assets/pattern-tile.svg');
    background-size: 620px;
    opacity: 0.024;
  }

  .stage__aura { inset: -20% -10%; }
  :global(html.cinema-on) .stage__aura { will-change: transform, opacity; }
  /* Warm candle-pool at the top for the Invitation. */
  .stage__aura--hero {
    background:
      radial-gradient(46% 40% at 50% 8%, rgb(var(--gold-500-rgb) / 0.16), transparent 66%),
      radial-gradient(38% 34% at 16% 4%, rgb(var(--green-400-rgb) / 0.15), transparent 60%),
      radial-gradient(38% 34% at 84% 4%, rgb(var(--gold-600-rgb) / 0.13), transparent 60%);
    opacity: 0.9;
  }
  /* A cooler greenery bloom rising from the left for The Two of Us. */
  .stage__aura--story {
    background:
      radial-gradient(40% 44% at 22% 62%, rgb(var(--green-400-rgb) / 0.20), transparent 64%),
      radial-gradient(34% 40% at 82% 40%, rgb(var(--gold-500-rgb) / 0.10), transparent 62%);
    opacity: 0;
  }

  .stage__glint {
    position: absolute;
    width: var(--gs, 6px);
    height: var(--gs, 6px);
    transform: rotate(45deg);
    background: var(--gold-300);
    opacity: 0.28;
    box-shadow: 0 0 10px 1px rgb(var(--gold-300-rgb) / 0.35);
    animation: glint-breathe calc(var(--gd, 1) * 6s) var(--ease-in-out) infinite;
  }
  @keyframes glint-breathe {
    0%, 100% { opacity: 0.14; }
    50% { opacity: 0.4; }
  }

  /* Without cinema, the story bloom shouldn't be fully hidden — let a hint
     of it sit under the section so the ground still feels layered. */
  :global(html:not(.cinema-on)) .stage__aura--story { opacity: 0.5; }

  @media (prefers-reduced-motion: reduce) {
    .stage__glint { animation: none; opacity: 0.22; }
  }
</style>
