---
import { wovenDivider } from '../lib/knots.mjs';
import { plaitDivider } from '../lib/ornaments.mjs';

// Both ornament sets ship; the `data-ornament` switch reveals one (see app.css).
const woven = wovenDivider({ width: 300 });
const plaited = plaitDivider({ width: 300 });
---

<div class="divider" role="separator" aria-hidden="true">
  <span class="divider__mark orn-woven" set:html={woven} />
  <span class="divider__mark orn-plaited" set:html={plaited} />
</div>

<style>
  .divider { display: flex; justify-content: center; padding-block: var(--space-2); }
  .divider__mark { display: block; width: min(300px, 64vw); }
  .divider__mark :global(svg) { display: block; width: 100%; height: auto; }
</style>
