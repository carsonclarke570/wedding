---
import Frame from './Frame.astro';
import { archBraid } from '../lib/knots.mjs';

// The rising-sun halo is a real Celtic knot band warped onto an arch (see
// knotwork.mjs), gilded sage→bronze→sage with a fan of fine rays. Both hands
// are emitted; the ornament switch reveals the one matching the rest of the
// page (woven rope vs plaited angular), exactly like the frames and dividers.
const archWoven = archBraid(820, 360, { hand: 'smooth', cordGradId: 'ggArchCordW' });
const archPlaited = archBraid(820, 360, { hand: 'geometric', cordGradId: 'ggArchCordG' });
---

<section id="top" class="hero" aria-labelledby="hero-title">
  <div class="hero__aura" aria-hidden="true"></div>

  <div class="hero__inner container--md">
    <span class="orn-woven"><svg class="hero__halo" aria-hidden="true" viewBox={archWoven.viewBox} preserveAspectRatio="xMidYMid meet" set:html={archWoven.svg}></svg></span>
    <span class="orn-plaited"><svg class="hero__halo" aria-hidden="true" viewBox={archPlaited.viewBox} preserveAspectRatio="xMidYMid meet" set:html={archPlaited.svg}></svg></span>
    <p class="hero__lead reveal-1">Together with their families</p>

    <h1 class="hero__names" id="hero-title">
      <span class="hero__name reveal-2">Warren</span>
      <span class="hero__amp reveal-2" aria-hidden="true">&amp;</span>
      <span class="hero__name reveal-2">Carson</span>
      <span class="sr-only">Warren and Carson</span>
    </h1>

    <Frame class="hero__frame reveal-3" tone="duo" pad="80px" data-strand-prop="0.35" data-max-tile="36">
      <p class="hero__date">
        <time datetime="2027-10-09">Saturday, the ninth of October</time>
        <span class="hero__year">Two Thousand Twenty-Seven</span>
      </p>
      <p class="hero__place">Rehoboth&nbsp;·&nbsp;Massachusetts</p>
    </Frame>

    <div class="chip-row hero__chips reveal-4">
      <span class="chip" data-tone="green">Black Tie Optional</span>
      <span class="chip" data-tone="bronze">Adults Only</span>
      <span class="chip">Kindly Reply by August 1</span>
    </div>

    <div class="hero__cta reveal-5">
      <a class="gg-btn" data-variant="duo" href="/rsvp">RSVP</a>
      <a class="gg-btn" data-variant="outline" href="#story">Our Story</a>
    </div>
  </div>

  <a class="hero__scroll reveal-5" href="#story" aria-label="Scroll to our story">
    <span class="hero__scroll-word">Begin</span>
    <span class="hero__scroll-track" aria-hidden="true"><span class="hero__scroll-dot"></span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: clamp(620px, 96svh, 920px);
    padding-block: var(--space-9) var(--space-8);
    overflow: hidden;
  }

  /* Symmetric aura: a warm bronze core flanked by two greenery blooms,
     lifting the dark strands of the duo sunburst off the near-black. */
  .hero__aura {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(120%, 1080px);
    aspect-ratio: 3 / 2;
    transform: translate(-50%, -54%);
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(42% 52% at 50% 42%, rgba(177, 138, 68, 0.16), transparent 70%),
      radial-gradient(40% 46% at 24% 54%, rgba(95, 116, 86, 0.20), transparent 72%),
      radial-gradient(40% 46% at 76% 54%, rgba(141, 107, 49, 0.18), transparent 72%);
    filter: blur(6px);
    opacity: 0;
    animation: soft-in var(--dur-veil) var(--ease-out) 80ms forwards;
  }

  .hero__inner { position: relative; z-index: 1; }

  /* The rising-sun arch crowns the names: anchored to the names block,
     wide enough that its woven feet flank the lettering and the gold crown
     rises above the eyebrow — symmetric, the couple sitting within it. */
  .hero__halo {
    position: absolute;
    left: 50%;
    top: clamp(-16px, -1vw, -4px);
    width: min(94%, 720px);
    height: auto;
    transform: translateX(-50%);
    z-index: -1;
    opacity: 0;
    overflow: visible;
    filter: drop-shadow(0 0 22px rgba(177, 138, 68, 0.16));
    animation: soft-in var(--dur-veil) var(--ease-out) 120ms forwards;
    pointer-events: none;
  }

  @keyframes soft-in { from { opacity: 0; } to { opacity: 1; } }

  .hero__lead {
    position: relative;
    z-index: 2;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--fs-body-lg);
    color: var(--text-soft);
    letter-spacing: 0.02em;
    margin-bottom: clamp(var(--space-5), 4vw, var(--space-6));
    text-shadow: 0 1px 10px var(--ink-800), 0 0 4px var(--ink-800);
  }

  .hero__names {
    display: flex;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0 clamp(var(--space-4), 3vw, var(--space-7));
    margin: 0;
    font-family: var(--font-celtic);
    font-weight: var(--fw-regular);
    font-size: clamp(42px, 10.5vw, 96px);
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }
  .hero__name { color: var(--parchment-100); }
  .hero__amp {
    font-family: var(--font-ornament);
    font-weight: var(--fw-regular);
    color: var(--gold-400);
    font-size: 0.9em;
    text-shadow: 0 0 26px rgba(230, 203, 142, 0.32);
  }

  .hero__frame {
    width: min(100%, 500px);
    margin: clamp(var(--space-6), 5vw, var(--space-7)) auto 0;
  }

  .hero__date {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: var(--fw-regular);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--parchment-200);
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
  }
  .hero__year { font-size: 0.72em; color: var(--text-muted); letter-spacing: 0.14em; }

  .hero__place {
    margin: var(--space-4) 0 0;
    font-family: var(--font-deco);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-300);
  }

  .hero__chips { margin-top: var(--space-6); }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
    margin-top: var(--space-7);
  }

  .hero__scroll {
    position: relative;
    z-index: 1;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-top: clamp(var(--space-6), 6vh, var(--space-9));
    color: var(--text-muted);
    font-family: var(--font-deco);
    font-size: 11px;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }
  .hero__scroll:hover { color: var(--gold-300); }
  .hero__scroll-track {
    width: 1px; height: 40px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .hero__scroll-dot {
    position: absolute;
    inset-inline: -1px;
    top: 0;
    height: 12px;
    background: var(--gold-400);
    animation: scroll-fall 2.6s var(--ease-in-out) infinite;
  }
  @keyframes scroll-fall {
    0% { transform: translateY(-14px); opacity: 0; }
    35% { opacity: 1; }
    100% { transform: translateY(40px); opacity: 0; }
  }

  /* ---- Staggered veil reveal (CSS-only; settles fully visible) ---- */
  .reveal-1, .reveal-2, .reveal-3, .reveal-4, .reveal-5 {
    opacity: 0;
    animation: veil-rise var(--dur-slow) var(--ease-out) forwards;
  }
  .reveal-1 { animation-delay: 220ms; }
  .reveal-2 { animation-delay: 360ms; }
  .reveal-3 { animation-delay: 540ms; }
  .reveal-4 { animation-delay: 700ms; }
  .reveal-5 { animation-delay: 860ms; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__aura { opacity: 1; animation: none; }
    .hero__halo { opacity: 1; animation: none; }
    .reveal-1, .reveal-2, .reveal-3, .reveal-4, .reveal-5 { opacity: 1; animation: none; }
    .hero__scroll-dot, .hero__rule-gem { animation: none; }
    .hero__scroll-dot { opacity: 1; top: 14px; }
  }

  @media (max-width: 600px) {
    .hero__names {
      flex-direction: column;
      align-items: center;
      gap: var(--space-1);
      font-size: clamp(38px, 8.5vw, 60px);
    }
    .hero__amp { font-size: 0.92em; line-height: 0.8; }
    .hero__date { font-size: var(--fs-body); letter-spacing: 0.05em; }
    .hero__place { letter-spacing: 0.2em; }
    .hero__chips .chip { font-size: 11px; padding: 6px 11px; letter-spacing: 0.1em; }
    .hero__halo { top: clamp(-34px, -6vw, -18px); width: min(78%, 340px); }
  }
</style>
