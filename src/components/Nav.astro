---
import monogram from '../../design-system/assets/monogram.svg?raw';

const links = [
  { href: '#story', label: 'Our Story' },
  { href: '#day', label: 'The Day' },
  { href: '#travel', label: 'Travel & Stay' },
  { href: '#registry', label: 'Registry' },
];
---

<header class="nav" data-nav>
  <div class="nav__inner container">
    <a class="nav__brand" href="#top" aria-label="Warren and Carson — home">
      <span class="nav__monogram" aria-hidden="true" set:html={monogram} />
      <span class="nav__names">
        Warren <span class="nav__amp">&amp;</span> Carson
      </span>
    </a>

    <button
      class="nav__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="nav-menu"
      data-nav-toggle
    >
      <span class="nav__toggle-bars" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="sr-only">Menu</span>
    </button>

    <nav class="nav__menu" id="nav-menu" aria-label="Primary">
      <ul class="nav__list">
        {links.map((l) => (
          <li><a class="gg-link nav__link" href={l.href}>{l.label}</a></li>
        ))}
      </ul>
      <a class="gg-btn gg-btn--sm" data-variant="duo" href="/rsvp">RSVP</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(12, 14, 12, 0.82);
    backdrop-filter: blur(10px) saturate(1.1);
    -webkit-backdrop-filter: blur(10px) saturate(1.1);
    border-bottom: 1px solid var(--line-soft);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--nav-h);
    gap: var(--space-4);
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--parchment-100);
  }
  .nav__brand:hover { color: var(--parchment-100); }
  .nav__monogram {
    display: block;
    width: 46px;
    height: 46px;
    flex: 0 0 auto;
  }
  .nav__monogram :global(svg) { display: block; width: 100%; height: 100%; }
  .nav__names {
    font-family: var(--font-display);
    font-size: 15px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .nav__amp {
    font-family: var(--font-ornament);
    color: var(--gold-400);
    margin-inline: 1px;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-5), 3vw, var(--space-7));
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-5), 2.6vw, var(--space-7));
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    font-family: var(--font-deco);
    font-size: 14px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--parchment-200);
  }
  .nav__link::after { background: var(--gold-400); }

  .nav__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .nav__toggle-bars { display: grid; gap: 5px; width: 20px; }
  .nav__toggle-bars i {
    display: block;
    height: 1.5px;
    background: var(--parchment-100);
    transition: transform var(--dur-base) var(--ease-out), opacity var(--dur-fast) var(--ease-out);
  }
  .nav[data-open] .nav__toggle-bars i:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav[data-open] .nav__toggle-bars i:nth-child(2) { opacity: 0; }
  .nav[data-open] .nav__toggle-bars i:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }


  @media (max-width: 860px) {
    .nav__toggle { display: inline-flex; }
    .nav__names { display: none; }
    .nav__menu {
      position: fixed;
      inset: var(--nav-h) 0 auto 0;
      z-index: var(--z-nav-menu);
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-5);
      padding: var(--space-6) var(--gutter) var(--space-7);
      background: rgba(12, 14, 12, 0.97);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-lg);
      transform: translateY(-12px);
      opacity: 0;
      visibility: hidden;
      transition: transform var(--dur-base) var(--ease-out),
                  opacity var(--dur-base) var(--ease-out),
                  visibility var(--dur-base) var(--ease-out);
    }
    .nav[data-open] .nav__menu { transform: none; opacity: 1; visibility: visible; }
    .nav__list { flex-direction: column; align-items: stretch; gap: var(--space-5); }
    .nav__link { font-size: 17px; }
    .nav__menu .gg-btn { width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__menu { transition: opacity var(--dur-fast) linear, visibility var(--dur-fast) linear; transform: none; }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.getElementById('nav-menu');

  if (nav && toggle && menu) {
    const setOpen = (open: boolean) => {
      nav.toggleAttribute('data-open', open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Close after choosing a destination, and on Escape / desktop resize.
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
    const mq = window.matchMedia('(min-width: 861px)');
    mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
  }
</script>
