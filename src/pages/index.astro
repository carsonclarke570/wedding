---
import Layout from '../layouts/Layout.astro';
import Stage from '../components/Stage.astro';
import Nav from '../components/Nav.astro';
import ActIndex from '../components/ActIndex.astro';
import Invitation from '../components/acts/Invitation.astro';
import StoryWeave from '../components/acts/StoryWeave.astro';
import Day from '../components/Day.astro';
import Travel from '../components/Travel.astro';
import Registry from '../components/Registry.astro';
import RsvpCta from '../components/RsvpCta.astro';
import Footer from '../components/Footer.astro';
import Bridge from '../components/Bridge.astro';
---

<Layout>
  <Stage />
  <Nav />
  <ActIndex />

  <main id="main">
    <Invitation />
    <StoryWeave />
    <Bridge quote="Enough about us — for now, at least." cta={{ label: "The Day", href: "#day" }} />
    <Day />
    <Bridge quote="Getting to us is, we promise, the easy part." cta={{ label: "Travel & Stay", href: "#travel" }} />
    <Travel />
    <Bridge quote="Your presence is genuinely the whole point. We mean that." cta={{ label: "The Registry", href: "#registry" }} />
    <Registry />
    <RsvpCta />
  </main>

  <Footer />
</Layout>

<script>
  // The cinematic layer — Lenis + GSAP ScrollTrigger. Self-gates on
  // reduced-motion / touch / narrow viewports; the page is complete without it.
  import '../scripts/cinema.ts';
</script>
