---
import '../styles/app.css';

import OrnamentToggle from '../components/OrnamentToggle.astro';

interface Props {
  title?: string;
  description?: string;
  ornamentToggle?: boolean;
}

const {
  title = 'Warren & Carson — September 19, 2026',
  description = 'Together with their families, Warren and Carson invite you to celebrate their wedding in Rehoboth, Massachusetts, on the nineteenth of September, 2026.',
  ornamentToggle = true,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-ornament="plaited">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#121110" />

    {/* Restore the chosen ornament set before paint (temporary preview switch). */}
    <script is:inline>
      try {
        var q = new URLSearchParams(location.search).get('ornament');
        var m = q || localStorage.getItem('gg-ornament');
        if (m === 'woven' || m === 'plaited') {
          document.documentElement.dataset.ornament = m;
          if (q) localStorage.setItem('gg-ornament', q);
        }
      } catch (e) {}
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    {ornamentToggle && <OrnamentToggle />}

    <style>
      .skip-link {
        position: fixed;
        top: var(--space-3);
        left: var(--space-3);
        z-index: var(--z-overlay);
        padding: 10px 16px;
        background: var(--ink-700);
        border: 1px solid var(--line-strong);
        border-radius: var(--radius-sm);
        color: var(--parchment-100);
        font-family: var(--font-deco);
        letter-spacing: var(--ls-label);
        text-transform: uppercase;
        font-size: 13px;
        transform: translateY(-160%);
        transition: transform var(--dur-base) var(--ease-out);
      }
      .skip-link:focus { transform: none; }
    </style>
  </body>
</html>
